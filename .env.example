# Environment Configuration
NODE_ENV=development

# Application
NEXT_PUBLIC_APP_NAME=Notes Demo
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Storage (SQLite)
# Path to the SQLite database file. Defaults to <project>/data/notes.db.
# Use ":memory:" for an ephemeral, in-process database (e.g. tests).
# SQLITE_DB_PATH=./data/notes.db

# API authentication
# Shared secret required in the `x-api-key` header for write endpoints
# (POST/PUT/DELETE). When unset, authentication is DISABLED and writes are open
# (convenient for local dev). Set a value in production to require the key.
# API_KEY=change-me
