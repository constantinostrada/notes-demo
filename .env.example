# Environment Configuration
NODE_ENV=development

# Application
NEXT_PUBLIC_APP_NAME=Notes Demo
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Storage (SQLite)
# Path to the SQLite database file. Defaults to <project>/data/notes.db.
# Use ":memory:" for an ephemeral, in-process database (e.g. tests).
# SQLITE_DB_PATH=./data/notes.db
